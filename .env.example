# API Keys - copy this to .env and fill in values
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
HUNTER_IO_API_KEY=optional_email_finder_key
APOLLO_API_KEY=optional_apollo_key
PROXYCURL_API_KEY=optional_linkedin_enrichment_key

# Rate limiting (requests per second)
DEFAULT_RPS=2.0
GOOGLE_PLACES_RPS=10.0

# Output
OUTPUT_DIR=./data/output
CACHE_DIR=./data/cache

# Targeting
TARGET_STATES=FL,GA,AL,SC,NC,TN
MIN_BEDS=20
MAX_BEDS=120
MIN_AGE_YEARS=5
MAX_AGE_YEARS=25

# Proxy pool — comma-separated http(s)://user:pass@host:port URLs
# Leave blank to disable rotation. Only use with sources that permit it.
PROXY_POOL=

# Headless browser
HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# CRM sync (optional)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_LEADS=Leads
AIRTABLE_TABLE_ACTIVITIES=Activities

NOTION_API_KEY=
NOTION_DATABASE_LEADS=

# Sender identity (used in templates)
SENDER_NAME=
SENDER_TITLE=Managing Partner
SENDER_FIRM=Acme Senior Housing Partners
SENDER_EMAIL=
SENDER_PHONE=
SENDER_CALENDAR_LINK=

# Property records (national)
REGRID_API_KEY=
REPORTALL_API_KEY=
ATTOM_API_KEY=

# Skip tracing
ENDATO_API_KEY=
ENDATO_API_NAME=
BATCH_SKIP_TRACING_API_KEY=

# Direct mail
LOB_API_KEY=
RETURN_ADDRESS_NAME=
RETURN_ADDRESS_STREET=
RETURN_ADDRESS_CITY=
RETURN_ADDRESS_STATE=
RETURN_ADDRESS_ZIP=

# Census API (free; required for high-volume calls)
CENSUS_API_KEY=

# Database (optional — defaults to SQLite. Set to a postgres:// URL on Render/Heroku)
DATABASE_URL=

# Logging
LOG_LEVEL=INFO

# Failure alerts
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
SLACK_WEBHOOK_URL=

# Incremental run policy
MAX_AGE_HOURS=168
FORCE_REBUILD=0
